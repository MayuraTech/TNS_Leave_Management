# Leave Management System - Environment Variables Configuration

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# PostgreSQL database connection URL
DB_URL=jdbc:postgresql://localhost:5432/leave_management

# Database username
DB_USERNAME=postgres

# Database password
DB_PASSWORD=your_database_password_here

# ============================================================================
# JWT CONFIGURATION
# ============================================================================
# JWT secret key for token signing (minimum 256 bits)
# IMPORTANT: Change this in production to a secure random value
JWT_SECRET=your-256-bit-secret-key-here-change-in-production

# JWT token expiration time in milliseconds (default: 1800000 = 30 minutes)
JWT_EXPIRATION=1800000

# ============================================================================
# SMTP EMAIL CONFIGURATION
# ============================================================================
# SMTP server hostname
SMTP_HOST=smtp.gmail.com

# SMTP server port (587 for TLS, 465 for SSL)
SMTP_PORT=587

# SMTP username (email address)
SMTP_USERNAME=your-email@example.com

# SMTP password or app-specific password
SMTP_PASSWORD=your_smtp_password_here

# ============================================================================
# CORS CONFIGURATION
# ============================================================================
# Allowed origins for CORS (comma-separated for multiple origins)
# Development: http://localhost:4200
# Production: https://your-production-domain.com
CORS_ALLOWED_ORIGINS=http://localhost:4200

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================
# Backend server port (default: 8080)
SERVER_PORT=8080

# ============================================================================
# NOTES
# ============================================================================
# 1. For Gmail SMTP, you may need to:
#    - Enable "Less secure app access" OR
#    - Generate an "App Password" if 2FA is enabled
#
# 2. For production deployment:
#    - Use strong, randomly generated JWT_SECRET
#    - Use secure database credentials
#    - Configure proper SMTP credentials
#    - Update CORS_ALLOWED_ORIGINS to your frontend domain
#
# 3. Never commit this file with actual credentials to version control
#    - Keep actual values in .env (which should be in .gitignore)
#    - Share this .env.example as a template
